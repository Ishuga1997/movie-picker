generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WatchedMovie {
  id        String   @id @default(uuid())
  userId    String
  tmdbId    Int
  movieData Json
  createdAt DateTime @default(now())

  @@unique([userId, tmdbId])
  @@index([userId])
}
